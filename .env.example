# Environment: development | test | production
NODE_ENV=development
PORT=3000

# PostgreSQL connection string. Do not commit real credentials.
# In production prefer DATABASE_URL_FILE=/run/secrets/movemgmt_database_url.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/movemgmt?schema=public"
# DATABASE_URL_FILE="/run/secrets/movemgmt_database_url"

# JWT. In production use long random secrets; no defaults are applied.
# In production prefer JWT_SECRET_FILE=/run/secrets/movemgmt_jwt_secret.
JWT_SECRET="CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARS"
# JWT_SECRET_FILE="/run/secrets/movemgmt_jwt_secret"
JWT_EXPIRES_IN="8h"
JWT_ISSUER="movemgmt-core-ms"
JWT_AUDIENCE="movemgmt-fe"

# CORS. Production must be exactly https://moveon.medinagroup.it
CORS_ORIGIN="http://localhost:5173,http://localhost:4173"

# Storage. In production mount host /opt/move/storage/movemgmt to container /app/storage.
STORAGE_ROOT_PATH="./storage"
DOCUMENTS_STORAGE_PATH="./storage/documents"
TEMP_STORAGE_PATH="./storage/tmp"
GENERATED_FILES_PATH="./storage/generated"
MAX_UPLOAD_SIZE_MB=12

# Logging and runtime behavior
LOG_LEVEL=debug
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
TRUST_PROXY=false
SWAGGER_ENABLED=true

# Security
PASSWORD_HASH_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
LOGIN_RATE_LIMIT_MAX_REQUESTS=10

# Encrypted CARGOS credentials secret. Use a random 32+ char value per environment.
# In production prefer CARGOS_CONFIG_SECRET_FILE=/run/secrets/movemgmt_cargos_config_secret.
CARGOS_CONFIG_SECRET="CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARS"
# CARGOS_CONFIG_SECRET_FILE="/run/secrets/movemgmt_cargos_config_secret"

# Contract rendering options
CONTRACT_CLIENT_SIGNATURE_PLACEHOLDER="[[FIRMA_CLIENTE]]"
CONTRACT_DEFAULT_SIGNATURE_WIDTH="180px"
CONTRACT_DEFAULT_SIGNATURE_HEIGHT="70px"
